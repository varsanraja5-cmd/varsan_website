---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  
  <!-- Contact Header -->
  <div class="mb-10 p-6 bg-skin-card rounded-lg border border-skin-line">
    <div class="text-4xl font-bold mb-4">Varsan Raja</div>
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-skin-text/80">
      <a href="tel:+13316664138" class="flex items-center gap-2 hover:text-skin-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        (331) 666-4138
      </a>
    </div>
  </div>

  <!-- Education -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="space-y-6 mb-10">
    <div class="pl-4 border-l-2 border-skin-accent/40 hover:border-skin-accent transition-colors">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
        <div>
          <h3 class="text-lg font-semibold">Oswego East High School</h3>
          <p class="text-skin-text/80">Current Highschool</p>
        </div>
        <span class="text-sm text-skin-text/60 whitespace-nowrap sm:text-right">Oswego, IL : Aug. 2025 -- May 2027</span>
      </div>
      <ul class="list-disc ml-5 mt-3 text-sm text-skin-text/70 grid gap-1.5">
        <li>GPA: 4.742 Weighted, 4.0 Unweighted</li>
        <li>Relevant Coursework: AP Computer Science A(Score: 5), AP Precalculus, AP Chemistry(Score: 5), and
AP Physics 1(Score: 5)</li>
        <li>SAT: 1460</li>
      </ul>
    </div>

    <div class="space-y-6 mb-10">
    <div class="pl-4 border-l-2 border-skin-accent/40 hover:border-skin-accent transition-colors">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
        <div>
          <h3 class="text-lg font-semibold">Metea Valley High School</h3>
          <p class="text-skin-text/80">10th Grade</p>
        </div>
        <span class="text-sm text-skin-text/60 whitespace-nowrap sm:text-right">Aurora, IL : Aug. 2024 -- June 2025</span>
      </div>
      <ul class="list-disc ml-5 mt-3 text-sm text-skin-text/70 grid gap-1.5">
        <li>GPA: 4.625 Weighted, 4.0 Unweighted</li>
        <li>Relevant Coursework: AP Computer Science Principles(Score: 5), Honors Algebra II w/ Trig & Stats,
and Honors Chemistry</li>
      </ul>
    </div>

    <div class="pl-4 border-l-2 border-skin-accent/40 hover:border-skin-accent transition-colors">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
        <div>
          <h3 class="text-lg font-semibold">Sri Chaitanya Techno School</h3>
          <p class="text-skin-text/80">9th Grade: CBSE + C-Batch syllabus focused on rigorous IIT-JEE preparation</p>
        </div>
        <span class="text-sm text-skin-text/60 whitespace-nowrap sm:text-right">Chennai, Tamil Nadu(India) : June 2023 -- June 2024</span>
      </div>
    </div>
  </div>

  <!-- Experience -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience & Projects</div>
  </div>

  <div class="space-y-8 mb-10">
    <div class="pl-4 border-l-2 border-skin-accent/40 hover:border-skin-accent transition-colors">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
        <div>
          <h3 class="text-lg font-semibold">ThinkNeuro – Software Engineering Practicum</h3>
          <p class="text-skin-text/80">Software Engineering Internship Experience — Remote</p>
        </div>
        <span class="text-sm text-skin-text/60 whitespace-nowrap sm:text-right">June 2026 – Aug. 2026</span>
      </div>
      <ul class="list-disc ml-5 mt-3 text-sm text-skin-text/70 grid gap-1.5">
        <li>Learned how to utilize Git and GitHub in team working environments for version control, code reviews,
and collaborative workflows</li>
        <li>Designed and deployed a personal portfolio website</li>
      </ul>
    </div>

    <div class="pl-4 border-l-2 border-skin-accent/40 hover:border-skin-accent transition-colors">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
        <div>
          <h3 class="text-lg font-semibold">Thirukkual App</h3>
          <p class="text-skin-text/80">Mobile Notification App inspired by the historical and cultural work: Thirukkural — Remote</p>
        </div>
        <span class="text-sm text-skin-text/60 whitespace-nowrap sm:text-right">June 2026 – Present</span>
      </div>
      <ul class="list-disc ml-5 mt-3 text-sm text-skin-text/70 grid gap-1.5">
        <li>Utilized AI-assisted development (Claude, ChatGPT, GLM) through AI-prompting to generate code,
troubleshoot bugs, and design core application logic</li>
        <li>Leveraged Expo tools to configure the development environment, execute cross-platform testing, and
deploy new app features</li>
        <li>Gained valuable experience in a two-person team, establishing Git workflows to manage project goals and
integrate code updates</li>
      </ul>
    </div>
  </div>

  <!-- Accomplishments -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Accomplishments</div>
  </div>

  <div class="space-y-8 mb-10">
    <div class="pl-4 border-l-2 border-skin-accent/40 hover:border-skin-accent transition-colors">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
        <div>
          <h3 class="text-lg font-semibold">Business Professionals of America(BPA)</h3>
        </div>
        <span class="text-sm text-skin-text/60 whitespace-nowrap sm:text-right">2025 – 2026 Academic Year</span>
      </div>
      <ul class="list-disc ml-5 mt-3 text-sm text-skin-text/70 grid gap-1.5">
        <li>Achieved 1st place in state level for Entrepreneurship</li>
        <li>Created, researched, innovated, developed, and presented a comprehensive business plan to a panel of
industry judges, competing against many other high school students from competitive schools.</li>
      </ul>
    </div>
  </div>

  <!-- Technical Skills -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Technical Skills</div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
    <div>
      <span class="font-semibold text-skin-text/90">Languages</span>
      <p class="text-skin-text/70 mt-1">Java</p>
    </div>
    <div>
      <span class="font-semibold text-skin-text/90">Soft Skills</span>
      <p class="text-skin-text/70 mt-1">Presentation and Problem Solving</p>
    </div>
    <div>
      <span class="font-semibold text-skin-text/90">Developer Tools</span>
      <p class="text-skin-text/70 mt-1">Git, VS Code, PyCharm</p>
    </div>
    <div>
      <span class="font-semibold text-skin-text/90">Scientific Skills</span>
      <p class="text-skin-text/70 mt-1">Data analysis and laboratory procedures(through AP Chemistry and AP Physics 1)</p>
    </div>
  </div>
</BaseLayout>
